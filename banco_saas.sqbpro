<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="banco_saas.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1661"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Saloes" custom_title="0" dock_id="1" table="4,6:mainSaloes"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Agendamentos" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="55"/><column index="3" value="85"/><column index="4" value="108"/><column index="5" value="67"/><column index="6" value="44"/><column index="7" value="115"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Saloes" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="1" mode="1"/></sort><column_widths><column index="1" value="35"/><column index="2" value="174"/><column index="3" value="127"/><column index="4" value="95"/><column index="5" value="308"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Servicos" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="55"/><column index="3" value="88"/><column index="4" value="40"/><column index="5" value="98"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- 1. Desativa a trava de segurança temporariamente
PRAGMA foreign_keys = OFF;

-- 2. Limpa as tabelas antigas com defeito
DROP TABLE IF EXISTS Agendamentos;
DROP TABLE IF EXISTS Servicos;
DROP TABLE IF EXISTS Saloes;

-- 3. Ativa a trava novamente
PRAGMA foreign_keys = ON;

-- 4. Recria a tabela Saloes com a Chave Mestre (PK) perfeita
CREATE TABLE &quot;Saloes&quot; (
    &quot;id&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
    &quot;nome_salao&quot; TEXT,
    &quot;slug&quot; TEXT,
    &quot;telefone&quot; TEXT,
    &quot;mp_access_token&quot; TEXT
);

-- 5. Recria a tabela Servicos
CREATE TABLE &quot;Servicos&quot; (
    &quot;id&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
    &quot;id_salao&quot; INTEGER,
    &quot;nome_servico&quot; TEXT,
    &quot;preco&quot; REAL,
    &quot;tempo_duracao&quot; INTEGER,
    FOREIGN KEY(&quot;id_salao&quot;) REFERENCES &quot;Saloes&quot;(&quot;id&quot;)
);

-- 6. Recria a tabela Agendamentos
CREATE TABLE &quot;Agendamentos&quot; (
    &quot;id&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
    &quot;id_salao&quot; INTEGER,
    &quot;nome_cliente&quot; TEXT,
    &quot;whatsapp_cliente&quot; TEXT,
    &quot;data_hora&quot; TEXT,
    &quot;status&quot; TEXT DEFAULT 'Pendente',
    &quot;id_pagamento_mp&quot; TEXT,
    FOREIGN KEY(&quot;id_salao&quot;) REFERENCES &quot;Saloes&quot;(&quot;id&quot;)
);

-- 7. Já insere a sua Barbearia Teste e o Serviço de Corte!
INSERT INTO Saloes (nome_salao, slug, telefone, mp_access_token)
VALUES ('Barbearia Teste', 'barbearia-teste', '16994221182', 'token_teste_123');

INSERT INTO Servicos (id_salao, nome_servico, preco, tempo_duracao)
VALUES (1, 'Corte Degradê', 45.00, 45);</sql><current_tab id="0"/></tab_sql></sqlb_project>
